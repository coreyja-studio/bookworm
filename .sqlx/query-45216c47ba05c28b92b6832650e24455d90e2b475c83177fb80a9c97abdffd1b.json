  "query": "SELECT b.book_id, b.title, b.author, r.read_date, b.cover_url as \"cover_url?\"\n           FROM reads r JOIN books b ON b.book_id = r.book_id\n           WHERE r.deleted_at IS NULL\n           ORDER BY r.created_at DESC LIMIT 3",
